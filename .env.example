# Local development environment.
# Copy to .env and fill in the blanks. .env is gitignored.
# Production values live in Fly secrets, not in any committed file.

# --- Database ---
DATABASE_URL=postgres://chatapp:chatapp_dev@localhost:5432/chatapp

# --- Server ---
PORT=8080
LOG_LEVEL=info
# Number of machines the GLOBAL rate-limit caps are divided across (§6). Set to
# your provisioned machine count (`fly scale count`); 1 = single machine = exact
# caps. See "Rate limiting" in apps/server/CLAUDE.md.
# RATE_LIMIT_MACHINE_COUNT=1

# --- Email (Resend) ---
# Required for signup verification and password-reset emails.
RESEND_API_KEY=

# --- Web Push (VAPID) ---
# Required for closed-tab notifications. Generate once with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Bot providers ---
# The active provider is BOT_PROVIDER *and* its key below. With neither key set,
# bot replies fall back to a logged-style stub (no model call) — like the email
# sender when RESEND_API_KEY is unset. Set BOT_PROVIDER to "anthropic" or "openai".
BOT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model overrides (defaults: claude-opus-4-8 / gpt-4o).
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o
# Per-user/day token budget for bot replies (input + output); default 20000.
# BOT_DAILY_TOKEN_BUDGET=20000
