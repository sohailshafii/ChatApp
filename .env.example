# Local development environment.
# Copy to .env and fill in the blanks. .env is gitignored.
# Production values live in Fly secrets, not in any committed file.

# --- Database ---
DATABASE_URL=postgres://chatapp:chatapp_dev@localhost:5432/chatapp

# --- Server ---
PORT=8080
LOG_LEVEL=info

# --- Email (Resend) ---
# Required for signup verification and password-reset emails.
RESEND_API_KEY=

# --- Web Push (VAPID) ---
# Required for closed-tab notifications. Generate once with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Bot providers ---
# Active provider per bot is decided server-side. Set BOT_PROVIDER to "anthropic" or "openai".
BOT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
