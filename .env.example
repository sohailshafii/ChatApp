# Local development environment.
# Copy to .env and fill in the blanks. .env is gitignored.
# Production values live in Fly secrets, not in any committed file.

# --- Database ---
DATABASE_URL=postgres://chatapp:chatapp_dev@localhost:5432/chatapp

# --- Server ---
PORT=8080
LOG_LEVEL=info
# Days to keep auth audit events before the retention sweeper prunes them (§6).
# AUDIT_RETENTION_DAYS=180
# Invite-only signup (§1): when true, POST /auth/signup requires a pending invite
# matching the email (mint with `npm run invite -- <email>`); uninvited signups
# get invite_required. Off by default = open signup. Only "true"/"1" enable it.
# INVITE_ONLY=false

# --- Email (Resend) ---
# Required for signup verification and password-reset emails. When unset, those
# links are logged to the server console instead of emailed (fine for local dev).
RESEND_API_KEY=
# From address on outgoing mail. Resend only sends from a domain verified in your
# account; the default works out-of-the-box for testing (delivered to the Resend
# account owner). A bare personal address on an unverified domain will be rejected.
# Accepts "Name <email>" too. Defaults to onboarding@resend.dev.
MAIL_FROM=onboarding@resend.dev

# --- Web Push (VAPID) ---
# Required for closed-tab notifications. Generate once with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Redis / Valkey (multi-machine scale-out) ---
# Optional. When unset (the default), rate-limit counters stay in-process and the
# app runs on a single machine (N=1). When set, the rate-limit counters + login
# backoff use this shared store, so their caps become exact GLOBAL (whole-fleet)
# caps across machines (no per-machine division needed). The WS hub fan-out moves
# to it in a later phase. See docs/multi-machine.md.
# REDIS_URL=redis://localhost:6379

# --- Bot providers ---
# The active provider is BOT_PROVIDER *and* its key below. With neither key set,
# bot replies fall back to a logged-style stub (no model call) — like the email
# sender when RESEND_API_KEY is unset. Set BOT_PROVIDER to "anthropic" or "openai".
BOT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model overrides (defaults: claude-opus-4-8 / gpt-4o).
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o
# Per-user/day token budget for bot replies (input + output); default 20000.
# BOT_DAILY_TOKEN_BUDGET=20000
