{
  "name": "@chatapp/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "migrate": "tsx --env-file-if-exists=../../.env src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chatapp/shared": "*",
    "@fastify/cookie": "^11.0.0",
    "argon2": "^0.41.1",
    "fastify": "^5.2.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.7.0",
    "vitest": "^2.1.0"
  }
}
